# Google Gemini (required for LLM analysis and answer grading)
# Get a free API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Proctoring severity thresholds (seconds unless noted)
GAZE_LOW_SEC=2.0
GAZE_MEDIUM_SEC=5.0
FACE_NOT_DETECTED_SEC=5.0
CONNECTION_TIMEOUT_SEC=30.0

# Integrity score risk bands (0-1)
RISK_LOW_MIN_SCORE=0.75
RISK_MEDIUM_MIN_SCORE=0.50

# Session TTL (seconds)
SESSION_TTL_SEC=3600

# ZIP extraction limits
MAX_ZIP_FILES=200
MAX_ZIP_UNCOMPRESSED_BYTES=52428800
MAX_SNIPPET_CHARS=8000

# CORS — use * for network access from other devices
CORS_ORIGINS=*

# Server bind (0.0.0.0 allows access from other devices on your network)
HOST=0.0.0.0
PORT=8000
